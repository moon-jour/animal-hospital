{
  "name": "animal-hospital",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "dev:test": "next dev -H 127.0.0.1 -p 4173",
    "sync:site": "node scripts/sync-site-script.mjs",
    "predev": "npm run sync:site",
    "predev:test": "npm run sync:site",
    "prebuild": "npm run sync:site",
    "pretest": "npm run sync:site",
    "build": "next build",
    "start": "next start",
    "test": "playwright test",
    "audit:prod": "npm audit --omit=dev",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "ci": "npm run audit:prod && npm run build && npm run scan:secrets && npm test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0",
    "next": "^16.2.6",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
